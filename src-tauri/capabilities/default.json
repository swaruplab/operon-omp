{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "updater:default",
    "process:allow-restart",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/rg",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
